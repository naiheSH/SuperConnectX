# Auto detect text files and perform LF normalization
* text=auto

# 关键配置：让 diff 时忽略换行符差异（CRLF vs LF）
# 这不会改变仓库中的换行符，只是在 diff 对比时忽略
* -text

# 源码文件统一使用 LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Windows 批处理文件必须保持 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.svg binary
*.woff binary
*.woff2 binary
